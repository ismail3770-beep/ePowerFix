{
  "name": "epowerfix",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "bun run --cwd apps/api typecheck && bun run --cwd apps/web tsc --noEmit --pretty false && bun run --cwd apps/mobile tsc --noEmit --pretty false",
    "test": "bun test --reporter=dots",
    "check": "bun run test && bun run typecheck",
    "security:audit": "bun scripts/security-audit.ts",
    "start": "bun run --cwd apps/api start",
    "dev:web": "turbo dev --filter=@epowerfix/web",
    "dev:api": "turbo dev --filter=@epowerfix/api",
    "dev:mobile": "bun run --cwd apps/mobile dev",
    "mobile:android": "bun run --cwd apps/mobile android",
    "mobile:ios": "bun run --cwd apps/mobile ios",
    "build:web": "turbo build --filter=@epowerfix/web",
    "build:api": "turbo build --filter=@epowerfix/api",
    "lint:web": "turbo lint --filter=@epowerfix/web",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma",
    "db:seed": "bun prisma/seed.ts",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": "1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
