{
  "name": "epowerfix",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "start": "cd apps/api && bun run start",
    "dev:web": "turbo dev --filter=@epowerfix/web",
    "dev:api": "turbo dev --filter=@epowerfix/api",
    "build:web": "turbo build --filter=@epowerfix/web",
    "build:api": "turbo build --filter=@epowerfix/api",
    "lint:web": "turbo lint --filter=@epowerfix/web",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma",
    "db:seed": "bun prisma/seed.ts",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.0",
  "dependencies": {
    "@prisma/client": "6.19.3"
  }
}
