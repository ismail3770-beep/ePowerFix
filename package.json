{
  "name": "epowerfix",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@epowerfix/web",
    "dev:api": "turbo run dev --filter=@epowerfix/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:push": "turbo run db:push",
    "db:generate": "turbo run db:generate",
    "db:seed": "turbo run db:seed",
    "db:migrate": "turbo run db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.2",
    "typescript": "^5"
  }
}