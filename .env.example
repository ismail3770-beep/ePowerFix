# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Create the database first:
#   createdb -U postgres epowerfix
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/epowerfix?schema=public"

# ─── Secrets (generate with: openssl rand -base64 32) ─────────────────────────
# JWT secret for auth sessions (minimum 32 characters)
JWT_SECRET=""

# NextAuth secret (minimum 32 characters)
NEXTAUTH_SECRET=""

# ─── Public URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Payment Gateways (optional — leave empty for sandbox/test mode) ──────────
# SSLCOMMERZ_STORE_ID=""
# SSLCOMMERZ_STORE_PASSWORD=""
# BKASH_API_KEY=""
# BKASH_SECRET_KEY=""
# BKASH_PHONE_NUMBER=""
# NAGAD_API_KEY=""
# NAGAD_SECRET_KEY=""
# NAGAD_PHONE_NUMBER=""
