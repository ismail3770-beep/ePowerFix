# Database (PostgreSQL — local or Neon)
# Local:  postgresql://postgres:password@localhost:5432/epowerfix
# Neon:   postgresql://USER:PASSWORD@ep-cool-name-1234.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/epowerfix

# Auth (REQUIRED — replace with your own secrets)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_ISSUER=epowerfix
JWT_AUDIENCE=epowerfix-users

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin seed credentials (used by prisma/seed.ts and scripts/create-admin.ts)
# NEVER commit real values — override these in your local .env file.
ADMIN_EMAIL=admin@epowerfix.com
ADMIN_PASSWORD=change-me-on-first-login
ADMIN_NAME=ePowerFix Admin
ADMIN_NAME_BN=ই-পাওয়ার ফিক্স অ্যাডমিন
ADMIN_PHONE=+880000000000
