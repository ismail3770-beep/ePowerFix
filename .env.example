# ============ DATABASE ============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/epowerfix

# ============ AUTH ============
JWT_SECRET=your-super-secret-change-in-production

# ============ API ============
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============ SSLCOMMERZ ============
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password

# ============ bKASH ============
BKASH_STORE_ID=your_bkash_store_id
BKASH_STORE_PASSWORD=your_bkash_password

# ============ NAGAD ============
NAGAD_MERCHANT_ID=your_nagad_merchant_id
