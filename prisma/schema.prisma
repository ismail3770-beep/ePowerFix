  title       String
  description String?
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  discount    Float
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("flash_sales")
}

model Tax {
  id        String   @id @default(uuid())
  name      String
  rate      Float
  type      String   @default("PERCENTAGE")
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("taxes")
}

model ProductQuestion {
  id         String    @id @default(uuid())
  productId  String    @map("product_id")
  userId     String    @map("user_id")
  question   String
  answer     String?
  answeredAt DateTime? @map("answered_at")
  isDeleted  Boolean   @default(false) @map("is_deleted")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("product_questions")
}

// ==================== SITE SETTINGS ====================

model SiteSettings {
  id String @id @default("default")

  // Brand
  siteName    String  @default("ePowerFix") @map("site_name")
  siteTagline String? @map("site_tagline")
  logoUrl     String? @map("logo_url")
  faviconUrl  String? @map("favicon_url")

  // Colors (hex without #)
  primaryColor   String @default("0EA5E9") @map("primary_color")
  secondaryColor String @default("0284C7") @map("secondary_color")
  accentColor    String @default("4D7300") @map("accent_color")
  headerBg       String @default("FFFFFF") @map("header_bg")
  footerBg       String @default("111827") @map("footer_bg")
  bodyBg         String @default("F8FAFC") @map("body_bg")

  // Typography
  headingFont String @default("Geist Sans") @map("heading_font")
  bodyFont    String @default("Geist Sans") @map("body_font")
  fontSize    String @default("16") @map("font_size")

  // Layout
  containerWidth String @default("1280") @map("container_width")

  // Social links
  facebookUrl  String? @map("facebook_url")
  instagramUrl String? @map("instagram_url")
  twitterUrl   String? @map("twitter_url")
  youtubeUrl   String? @map("youtube_url")
  linkedinUrl  String? @map("linkedin_url")

  // Contact
  phone   String?
  email   String?
  address String?

  // Footer
  copyrightText String @default("© 2025 ePowerFix. All rights reserved.") @map("copyright_text")

  // Meta
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  // Payment Gateways — bKash
  bkashEnabled     Boolean @default(false) @map("bkash_enabled")
  bkashPhoneNumber String? @map("bkash_phone_number")
  bkashApiKey      String? @map("bkash_api_key")
  bkashSecretKey   String? @map("bkash_secret_key")
  bkashSandbox     Boolean @default(true) @map("bkash_sandbox")

  // Payment Gateways — Nagad
  nagadEnabled     Boolean @default(false) @map("nagad_enabled")
  nagadPhoneNumber String? @map("nagad_phone_number")
  nagadApiKey      String? @map("nagad_api_key")
  nagadSecretKey   String? @map("nagad_secret_key")
  nagadSandbox     Boolean @default(true) @map("nagad_sandbox")

  // Payment Gateways — SSLCommerz
  sslcommerzEnabled       Boolean @default(false) @map("sslcommerz_enabled")
  sslcommerzStoreId       String? @map("sslcommerz_store_id")
  sslcommerzStorePassword String? @map("sslcommerz_store_password")
  sslcommerzSandbox       Boolean @default(true) @map("sslcommerz_sandbox")

  // Payment Gateways — Bank Transfer
  bankTransferEnabled      Boolean @default(false) @map("bank_transfer_enabled")
  bankTransferInstructions String? @map("bank_transfer_instructions")

  // Payment Gateways — Cash on Delivery
  codEnabled Boolean @default(true) @map("cod_enabled")
  codFee     Float   @default(0) @map("cod_fee")

  // Shipping — flat delivery rates by zone
  shippingInsideDhaka       Float  @default(60) @map("shipping_inside_dhaka")
  shippingOutsideDhaka      Float  @default(120) @map("shipping_outside_dhaka")
  freeShippingThreshold     Float  @default(5000) @map("free_shipping_threshold")
  shippingInsideDhakaLabel  String @default("Inside Dhaka") @map("shipping_inside_dhaka_label")
  shippingOutsideDhakaLabel String @default("Outside Dhaka") @map("shipping_outside_dhaka_label")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ==================== AI PROVIDERS ====================

model AiProvider {
  id             String    @id @default(cuid())
  name           String
  type           String // OPENAI | ANTHROPIC | GEMINI | OLLAMA | OPENROUTER | OPENCODE | CUSTOM
  apiKey         String?
  baseUrl        String
  defaultModel   String
