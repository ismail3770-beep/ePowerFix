}

// ==================== ELECTRICIAN MARKETPLACE FOUNDATION ====================
// This domain is additive. It does not replace Service, ServiceBooking, Order, or Payment.
// Lifecycle values remain uppercase strings so transitions stay server-authoritative.

model ProviderProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  status             String    @default("DRAFT")
  displayName        String    @map("display_name")
  displayNameBn      String?   @map("display_name_bn")
  bio                String?
  yearsExperience    Int       @default(0) @map("years_experience")
  rating             Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount        Int       @default(0) @map("review_count")
  jobsCompleted      Int       @default(0) @map("jobs_completed")
  commissionRate     Decimal   @default(15) @map("commission_rate") @db.Decimal(5, 2)
  emergencyAvailable Boolean   @default(false) @map("emergency_available")
  isActive           Boolean   @default(true) @map("is_active")
  submittedAt        DateTime? @map("submitted_at")
  reviewedAt         DateTime? @map("reviewed_at")
  reviewedById       String?   @map("reviewed_by_id")
  rejectionReason    String?   @map("rejection_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user          User                    @relation("ProviderOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy    User?                   @relation("ProviderReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  documents     ProviderDocument[]
  skills        ProviderSkill[]
  serviceZones  ProviderServiceZone[]
  availability  ProviderAvailability[]
  timeOff       ProviderTimeOff[]
  assignments   JobAssignment[]
  jobs          MarketplaceJob[]
  quotes        MarketplaceQuote[]
  payments      MarketplacePayment[]
  ledgerEntries FinancialLedgerEntry[]
  payouts       ProviderPayout[]
  reviews       MarketplaceReview[]
  locationPings ProviderLocationPing[]
  auditEvents   MarketplaceAuditEvent[]

  @@index([status, isActive])
  @@index([reviewedById])
  @@index([rating])
  @@map("provider_profiles")
}

model ProviderDocument {
  id              String    @id @default(uuid())
  providerId      String    @map("provider_id")
  type            String
  storageKey      String    @map("storage_key")
  status          String    @default("PENDING")
  rejectionReason String?   @map("rejection_reason")
  reviewedById    String?   @map("reviewed_by_id")
  reviewedAt      DateTime? @map("reviewed_at")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reviewedBy User?           @relation("ProviderDocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([providerId, type])
  @@index([status])
  @@index([reviewedById])
  @@map("provider_documents")
}

model Skill {
  id          String   @id @default(uuid())
  name        String
  nameBn      String?  @map("name_bn")
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  providers ProviderSkill[]
  requests  MarketplaceServiceRequest[]

  @@index([isActive, sortOrder])
  @@map("marketplace_skills")
}

model ProviderSkill {
  id              String    @id @default(uuid())
  providerId      String    @map("provider_id")
  skillId         String    @map("skill_id")
  yearsExperience Int       @default(0) @map("years_experience")
  proficiency     String    @default("STANDARD")
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  skill    Skill           @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([providerId, skillId])
  @@index([skillId, isVerified])
  @@map("provider_skills")
}

model GeoDivision {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  nameBn    String?  @map("name_bn")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  districts GeoDistrict[]

  @@index([isActive])
  @@map("geo_divisions")
}

model GeoDistrict {
  id         String   @id @default(uuid())
  divisionId String   @map("division_id")
  code       String   @unique
  name       String
  nameBn     String?  @map("name_bn")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  division GeoDivision   @relation(fields: [divisionId], references: [id], onDelete: Restrict)
  upazilas GeoUpazila[]
  zones    ServiceZone[]

  @@index([divisionId, isActive])
  @@map("geo_districts")
}

model GeoUpazila {
  id         String   @id @default(uuid())
  districtId String   @map("district_id")
  code       String   @unique
  name       String
  nameBn     String?  @map("name_bn")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  district GeoDistrict   @relation(fields: [districtId], references: [id], onDelete: Restrict)
  zones    ServiceZone[]

  @@index([districtId, isActive])
  @@map("geo_upazilas")
}

model ServiceZone {
  id         String   @id @default(uuid())
  districtId String   @map("district_id")
  upazilaId  String?  @map("upazila_id")
  name       String
  nameBn     String?  @map("name_bn")
  slug       String   @unique
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  district  GeoDistrict                 @relation(fields: [districtId], references: [id], onDelete: Restrict)
  upazila   GeoUpazila?                 @relation(fields: [upazilaId], references: [id], onDelete: Restrict)
  providers ProviderServiceZone[]
  requests  MarketplaceServiceRequest[]

  @@index([districtId, isActive])
  @@index([upazilaId])
  @@map("service_zones")
}

model ProviderServiceZone {
  id                 String   @id @default(uuid())
  providerId         String   @map("provider_id")
  serviceZoneId      String   @map("service_zone_id")
  travelRadiusKm     Int      @default(10) @map("travel_radius_km")
  emergencyAvailable Boolean  @default(false) @map("emergency_available")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  serviceZone ServiceZone     @relation(fields: [serviceZoneId], references: [id], onDelete: Cascade)

  @@unique([providerId, serviceZoneId])
  @@index([serviceZoneId, isActive])
  @@map("provider_service_zones")
}

model ProviderAvailability {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  dayOfWeek  Int      @map("day_of_week")
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek, startTime, endTime])
  @@index([providerId, dayOfWeek, isActive])
  @@map("provider_availability")
}

model ProviderTimeOff {
  id         String   @id @default(uuid())
  providerId String   @map("provider_id")
  startsAt   DateTime @map("starts_at")
  endsAt     DateTime @map("ends_at")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, startsAt, endsAt])
  @@map("provider_time_off")
}

model MarketplaceSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  valueType   String   @default("STRING") @map("value_type")
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation("MarketplaceSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([isPublic])
  @@index([updatedById])
  @@map("marketplace_settings")
}

model MarketplaceAuditEvent {
  id          String   @id @default(uuid())
  actorUserId String?  @map("actor_user_id")
  providerId  String?  @map("provider_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  fromState   String?  @map("from_state")
  toState     String?  @map("to_state")
  metadata    String?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  actor    User?            @relation("MarketplaceAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  provider ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([providerId, createdAt])
  @@map("marketplace_audit_events")
}

model MarketplaceServiceRequest {
  id                 String    @id @default(uuid())
  customerId         String    @map("customer_id")
  serviceId          String?   @map("service_id")
  skillId            String?   @map("skill_id")
  serviceZoneId      String    @map("service_zone_id")
  idempotencyKey     String?   @unique @map("idempotency_key")
  status             String    @default("DRAFT")
  problemSummary     String    @map("problem_summary")
  description        String?
  serviceAddress     String    @map("service_address")
  areaName           String?   @map("area_name")
  latitude           Decimal?  @db.Decimal(10, 7)
  longitude          Decimal?  @db.Decimal(10, 7)
  scheduledFor       DateTime? @map("scheduled_for")
  isEmergency        Boolean   @default(false) @map("is_emergency")
  emergencySurcharge Decimal   @default(0) @map("emergency_surcharge") @db.Decimal(12, 2)
  cancellationReason String?   @map("cancellation_reason")
  submittedAt        DateTime? @map("submitted_at")
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  customer    User                       @relation("MarketplaceRequestCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  service     Service?                   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  skill       Skill?                     @relation(fields: [skillId], references: [id], onDelete: Restrict)
  serviceZone ServiceZone                @relation(fields: [serviceZoneId], references: [id], onDelete: Restrict)
  attachments ServiceRequestAttachment[]
  job         MarketplaceJob?

  @@index([customerId, status, createdAt])
  @@index([serviceZoneId, status, scheduledFor])
  @@index([skillId, status])
  @@index([serviceId])
  @@map("marketplace_service_requests")
}

model ServiceRequestAttachment {
  id         String   @id @default(uuid())
  requestId  String   @map("request_id")
  type       String
  storageKey String   @map("storage_key")
  caption    String?
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  request MarketplaceServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, sortOrder])
  @@map("service_request_attachments")
}

model MarketplaceJob {
  id                  String    @id @default(uuid())
  requestId           String    @unique @map("request_id")
  providerId          String?   @map("provider_id")
  status              String    @default("ASSIGNED")
  assignedAt          DateTime? @map("assigned_at")
  acceptedAt          DateTime? @map("accepted_at")
  enRouteAt           DateTime? @map("en_route_at")
  arrivedAt           DateTime? @map("arrived_at")
  workStartedAt       DateTime? @map("work_started_at")
  completedAt         DateTime? @map("completed_at")
  customerConfirmedAt DateTime? @map("customer_confirmed_at")
  cancelledAt         DateTime? @map("cancelled_at")
  cancellationReason  String?   @map("cancellation_reason")
  warrantyEndsAt      DateTime? @map("warranty_ends_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  request        MarketplaceServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Restrict)
  provider       ProviderProfile?           @relation(fields: [providerId], references: [id], onDelete: Restrict)
  assignments    JobAssignment[]
  statusHistory  JobStatusHistory[]
  quotes         MarketplaceQuote[]
  payments       MarketplacePayment[]
  reviews        MarketplaceReview[]
  warrantyClaims MarketplaceWarrantyClaim[]
  disputes       MarketplaceDispute[]
  arrivalOtps    ArrivalOtp[]
  locationPings  ProviderLocationPing[]

  @@index([providerId, status, createdAt])
  @@index([status, createdAt])
  @@map("marketplace_jobs")
}

model JobAssignment {
  id           String    @id @default(uuid())
  jobId        String    @map("job_id")
  providerId   String    @map("provider_id")
  assignedById String    @map("assigned_by_id")
  attempt      Int       @default(1)
  status       String    @default("OFFERED")
  score        Decimal?  @db.Decimal(7, 4)
  scoreDetails String?   @map("score_details")
  offeredAt    DateTime  @default(now()) @map("offered_at")
  expiresAt    DateTime? @map("expires_at")
  respondedAt  DateTime? @map("responded_at")
  responseNote String?   @map("response_note")

  job        MarketplaceJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Restrict)
  assignedBy User            @relation("AssignmentDispatcher", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([jobId, providerId, attempt])
  @@index([providerId, status, expiresAt])
  @@index([assignedById, offeredAt])
  @@map("job_assignments")
}

model JobStatusHistory {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  actorUserId String?  @map("actor_user_id")
  fromStatus  String?  @map("from_status")
  toStatus    String   @map("to_status")
  note        String?
  metadata    String?
  createdAt   DateTime @default(now()) @map("created_at")

  job   MarketplaceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  actor User?          @relation("JobStatusActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("job_status_history")
}

model MarketplaceQuote {
  id                   String    @id @default(uuid())
  jobId                String    @map("job_id")
  providerId           String    @map("provider_id")
  version              Int       @default(1)
  status               String    @default("DRAFT")
  subtotal             Decimal   @db.Decimal(12, 2)
  feeTotal             Decimal   @default(0) @map("fee_total") @db.Decimal(12, 2)
  taxTotal             Decimal   @default(0) @map("tax_total") @db.Decimal(12, 2)
  total                Decimal   @db.Decimal(12, 2)
  notes                String?
  expiresAt            DateTime? @map("expires_at")
  submittedAt          DateTime? @map("submitted_at")
  adminReviewedById    String?   @map("admin_reviewed_by_id")
  adminReviewedAt      DateTime? @map("admin_reviewed_at")
  customerDecisionById String?   @map("customer_decision_by_id")
  customerDecisionAt   DateTime? @map("customer_decision_at")
  customerDecisionNote String?   @map("customer_decision_note")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  job                MarketplaceJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider           ProviderProfile      @relation(fields: [providerId], references: [id], onDelete: Restrict)
  adminReviewedBy    User?                @relation("QuoteAdminReviewer", fields: [adminReviewedById], references: [id], onDelete: SetNull)
  customerDecisionBy User?                @relation("QuoteCustomerDecision", fields: [customerDecisionById], references: [id], onDelete: SetNull)
  lineItems          QuoteLineItem[]
  payments           MarketplacePayment[]

  @@unique([jobId, version])
  @@index([providerId, status, createdAt])
  @@index([status, expiresAt])
  @@map("marketplace_quotes")
}

model QuoteLineItem {
  id          String   @id @default(uuid())
  quoteId     String   @map("quote_id")
  type        String   @default("LABOR")
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  quote MarketplaceQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, sortOrder])
  @@map("quote_line_items")
}

model MarketplacePayment {
  id                    String    @id @default(uuid())
  jobId                 String    @map("job_id")
  quoteId               String?   @map("quote_id")
  customerId            String    @map("customer_id")
  providerId            String?   @map("provider_id")
  payoutId              String?   @map("payout_id")
  idempotencyKey        String    @unique @map("idempotency_key")
  type                  String
  method                String
  status                String    @default("CREATED")
  currency              String    @default("BDT")
  amount                Decimal   @db.Decimal(12, 2)
  commissionRate        Decimal   @default(0) @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount      Decimal   @default(0) @map("commission_amount") @db.Decimal(12, 2)
  providerNetAmount     Decimal   @default(0) @map("provider_net_amount") @db.Decimal(12, 2)
  externalTransactionId String?   @unique @map("external_transaction_id")
  gatewayReference      String?   @map("gateway_reference")
  gatewayData           String?   @map("gateway_data")
  paidAt                DateTime? @map("paid_at")
  failedAt              DateTime? @map("failed_at")
  refundedAt            DateTime? @map("refunded_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  job           MarketplaceJob         @relation(fields: [jobId], references: [id], onDelete: Restrict)
  quote         MarketplaceQuote?      @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  customer      User                   @relation("MarketplacePaymentCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  provider      ProviderProfile?       @relation(fields: [providerId], references: [id], onDelete: Restrict)
  payout        ProviderPayout?        @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  payoutItems   ProviderPayoutItem[]
  ledgerEntries FinancialLedgerEntry[]

  @@index([jobId, status, createdAt])
  @@index([customerId, createdAt])
  @@index([providerId, status])
  @@index([payoutId])
  @@map("marketplace_payments")
}

model FinancialLedgerEntry {
  id             String   @id @default(uuid())
  providerId     String   @map("provider_id")
  paymentId      String?  @map("payment_id")
  payoutId       String?  @map("payout_id")
  idempotencyKey String   @unique @map("idempotency_key")
  type           String
  direction      String
  currency       String   @default("BDT")
  amount         Decimal  @db.Decimal(12, 2)
  referenceType  String?  @map("reference_type")
  referenceId    String?  @map("reference_id")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  provider ProviderProfile     @relation(fields: [providerId], references: [id], onDelete: Restrict)
  payment  MarketplacePayment? @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  payout   ProviderPayout?     @relation(fields: [payoutId], references: [id], onDelete: Restrict)

  @@index([providerId, createdAt])
  @@index([paymentId])
  @@index([payoutId])
  @@index([referenceType, referenceId])
  @@map("financial_ledger_entries")
}

model ProviderPayout {
  id                String    @id @default(uuid())
  providerId        String    @map("provider_id")
  createdById       String    @map("created_by_id")
  approvedById      String?   @map("approved_by_id")
  idempotencyKey    String    @unique @map("idempotency_key")
  status            String    @default("DRAFT")
  currency          String    @default("BDT")
  grossAmount       Decimal   @map("gross_amount") @db.Decimal(12, 2)
  commissionAmount  Decimal   @default(0) @map("commission_amount") @db.Decimal(12, 2)
  adjustmentAmount  Decimal   @default(0) @map("adjustment_amount") @db.Decimal(12, 2)
  netAmount         Decimal   @map("net_amount") @db.Decimal(12, 2)
  method            String?
  destinationMasked String?   @map("destination_masked")
  externalReference String?   @unique @map("external_reference")
  periodStart       DateTime? @map("period_start")
  periodEnd         DateTime? @map("period_end")
  approvedAt        DateTime? @map("approved_at")
  paidAt            DateTime? @map("paid_at")
  failedAt          DateTime? @map("failed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  provider      ProviderProfile        @relation(fields: [providerId], references: [id], onDelete: Restrict)
  createdBy     User                   @relation("PayoutCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy    User?                  @relation("PayoutApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  payments      MarketplacePayment[]
  items         ProviderPayoutItem[]
  ledgerEntries FinancialLedgerEntry[]

  @@index([providerId, status, createdAt])
  @@index([createdById])
  @@index([approvedById])
  @@map("provider_payouts")
}

model ProviderPayoutItem {
  id               String   @id @default(uuid())
  payoutId         String   @map("payout_id")
  paymentId        String   @map("payment_id")
  grossAmount      Decimal  @map("gross_amount") @db.Decimal(12, 2)
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(12, 2)
  netAmount        Decimal  @map("net_amount") @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  payout  ProviderPayout     @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  payment MarketplacePayment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@unique([payoutId, paymentId])
  @@index([paymentId])
  @@map("provider_payout_items")
}

model MarketplaceReview {
  id         String   @id @default(uuid())
  jobId      String   @map("job_id")
  customerId String   @map("customer_id")
  providerId String   @map("provider_id")
  rating     Int
  comment    String?
  status     String   @default("PUBLISHED")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  job      MarketplaceJob  @relation(fields: [jobId], references: [id], onDelete: Restrict)
  customer User            @relation("MarketplaceReviewCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@unique([jobId, customerId])
  @@index([providerId, status, createdAt])
  @@map("marketplace_reviews")
}

model MarketplaceWarrantyClaim {
  id                  String    @id @default(uuid())
  jobId               String    @map("job_id")
  customerId          String    @map("customer_id")
  resolvedById        String?   @map("resolved_by_id")
  idempotencyKey      String    @unique @map("idempotency_key")
  status              String    @default("OPEN")
  issue               String
  providerResponse    String?   @map("provider_response")
  providerRespondedAt DateTime? @map("provider_responded_at")
  resolution          String?
  resolvedAt          DateTime? @map("resolved_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  job        MarketplaceJob @relation(fields: [jobId], references: [id], onDelete: Restrict)
  customer   User           @relation("WarrantyClaimCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  resolvedBy User?          @relation("WarrantyClaimResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([jobId, customerId])
  @@index([jobId, status])
  @@index([customerId, createdAt])
  @@index([resolvedById])
  @@map("marketplace_warranty_claims")
}

model MarketplaceDispute {
  id                  String    @id @default(uuid())
  jobId               String    @map("job_id")
  openedById          String    @map("opened_by_id")
  resolvedById        String?   @map("resolved_by_id")
  idempotencyKey      String    @unique @map("idempotency_key")
  status              String    @default("OPEN")
  category            String
  description         String
  providerResponse    String?   @map("provider_response")
  providerRespondedAt DateTime? @map("provider_responded_at")
  resolution          String?
  resolvedAt          DateTime? @map("resolved_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  job        MarketplaceJob @relation(fields: [jobId], references: [id], onDelete: Restrict)
  openedBy   User           @relation("DisputeOpener", fields: [openedById], references: [id], onDelete: Restrict)
  resolvedBy User?          @relation("DisputeResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([jobId, status])
  @@index([openedById, createdAt])
  @@index([resolvedById])
  @@map("marketplace_disputes")
}

model ArrivalOtp {
  id            String    @id @default(uuid())
  jobId         String    @map("job_id")
  codeHash      String    @map("code_hash")
  purpose       String    @default("ARRIVAL")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5) @map("max_attempts")
  expiresAt     DateTime  @map("expires_at")
  verifiedAt    DateTime? @map("verified_at")
  invalidatedAt DateTime? @map("invalidated_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  job MarketplaceJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, purpose, expiresAt])
  @@map("arrival_otps")
}

model ProviderLocationPing {
  id               String   @id @default(uuid())
  jobId            String   @map("job_id")
  providerId       String   @map("provider_id")
  latitude         Decimal  @db.Decimal(10, 7)
  longitude        Decimal  @db.Decimal(10, 7)
  accuracyMeters   Decimal? @map("accuracy_meters") @db.Decimal(8, 2)
  consentGrantedAt DateTime @map("consent_granted_at")
  capturedAt       DateTime @map("captured_at")
  createdAt        DateTime @default(now()) @map("created_at")

  job      MarketplaceJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  provider ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([jobId, capturedAt])
  @@index([providerId, capturedAt])
  @@map("provider_location_pings")
}

model NotificationDelivery {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  idempotencyKey    String    @unique @map("idempotency_key")
  channel           String
  template          String
  title             String
  message           String
  payload           String?
  status            String    @default("QUEUED")
  entityType        String?   @map("entity_type")
  entityId          String?   @map("entity_id")
  destinationMasked String?   @map("destination_masked")
  providerMessageId String?   @map("provider_message_id")
  failureReason     String?   @map("failure_reason")
  sentAt            DateTime? @map("sent_at")
  deliveredAt       DateTime? @map("delivered_at")
  readAt            DateTime? @map("read_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, status, createdAt])
  @@index([entityType, entityId])
  @@map("notification_deliveries")
}
