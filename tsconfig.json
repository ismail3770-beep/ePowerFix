{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@epowerfix/db": ["./packages/db/src"],
      "@epowerfix/types": ["./packages/types/src"],
      "@epowerfix/config": ["./packages/config/src"],
      "@epowerfix/utils": ["./packages/utils/src"],
      "@epowerfix/security": ["./packages/security/src"],
      "@epowerfix/i18n": ["./packages/i18n/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "ePowerFix", "src_backup_starter"]
}
