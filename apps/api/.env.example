# ─── ePowerFix API Environment Variables ───────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:3000

# Database (PostgreSQL — Neon)
DATABASE_URL=postgresql://postgres:password@localhost:5432/epowerfix?sslmode=require

# Auth (REQUIRED — replace with your own secrets)
# Production startup fails unless DATABASE_URL is set, WEB_URL is a non-local
# HTTP(S) URL, and JWT_SECRET contains at least 32 characters.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-min-32-chars-change-this
JWT_ISSUER=epowerfix
JWT_AUDIENCE=epowerfix-users

# Redis / Upstash (for shared caching and rate limiting). Optional, but URL and
# token must be configured together. In-memory fallbacks are process-local.
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── Payment Gateways ──────────────────────────────────────────────────────────
# Gateway integrations are optional for COD-only deployments. If any variable
# for a gateway is set, all variables in that gateway group are required.

# SSLCommerz
# SSLCOMMERZ_STORE_ID=your-store-id
# SSLCOMMERZ_STORE_PASSWD=your-store-password

# bKash
# BKASH_APP_KEY=your-app-key
# BKASH_APP_SECRET=your-app-secret
# BKASH_USERNAME=your-username
# BKASH_PASSWORD=your-password
# BKASH_CALLBACK_URL=http://localhost:3000/api/payments/bkash/callback

# Nagad
# NAGAD_MERCHANT_ID=your-merchant-id
# NAGAD_CALLBACK_URL=http://localhost:3000/api/payments/nagad/callback

# Local simulated gateway callbacks are disabled by default. Enable only for a
# local development session; this flag is ignored in production. Test-mode
# completions still require a one-time server-issued token.
# PAYMENT_TEST_MODE=true

# SSLCommerz v4 requires store_passwd in the validator GET query. Ensure your
# egress proxy, APM, and HTTP access logs redact the store_passwd parameter.

# Gateway callback allowlist. REQUIRED in production: POST callbacks fail closed
# when this is omitted or blank. Use the gateway's published source IPs/CIDRs,
# and ensure the reverse proxy is configured so Express req.ip is trustworthy.
# PAYMENT_CALLBACK_IP_WHITELIST=203.0.113.10,198.51.100.0/24

# Protected payment reservation cleanup job. Generate a high-entropy secret and
# send it only from your scheduler in the x-internal-job-secret header.
# PAYMENT_RESERVATION_CLEANUP_SECRET=replace-with-a-random-secret

# ─── Cloudinary (image storage) ────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (Resend — transactional email) ──────────────────────────────────────
# Order confirmation emails are sent when RESEND_API_KEY is set.
# Create a free account at https://resend.com to get your API key.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=ePowerFix <noreply@epowerfix.com.bd>

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
