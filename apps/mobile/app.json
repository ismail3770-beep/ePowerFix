{
  "expo": {
    "name": "ePowerFix",
    "slug": "epowerfix",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "epowerfix",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0EA5E9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.epowerfix.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0EA5E9"
      },
      "package": "com.epowerfix.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "c19c58d0-fd50-4fe7-afeb-20252f773e5f"
      },
      "router": {}
    },
    "owner": "epowerfix",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c19c58d0-fd50-4fe7-afeb-20252f773e5f"
    }
  }
}
