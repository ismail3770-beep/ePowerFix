# PostgreSQL connection string — update with your local PostgreSQL credentials.
# Create the database first:  createdb -U postgres epowerfix
# Then set the URL below to match your local credentials.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/epowerfix?schema=public"

# JWT secret for auth sessions (any long random string — change in production)
JWT_SECRET="ePowerFix-super-secret-jwt-key-2024-very-long-and-secure-7f3a9b2c8d1e"

# NextAuth secret (any long random string — change in production)
NEXTAUTH_SECRET="ePowerFix-nextauth-secret-2024"

# Public base URL (used for metadata / sitemap)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
