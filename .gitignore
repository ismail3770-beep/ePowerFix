# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# Development screenshots / debug images
/upload/

# Tool output dumps (AI/dev tool results)
/tool-results/

# Empty download placeholder (runtime-generated)
/download/

# Nested duplicate prisma folder (accidental)
/prisma/prisma/

# Build output for local packages
/packages/*/dist/

# Runtime process id files
*.pid

# Dev worklog and internal report files (not needed for the website)
worklog.md
project-report.html
PROJECT_REPORT.pdf
PROJECT_REPORT.md
ENTERPRISE_ROADMAP.md
SENTRY_ALERTING_GUIDE.md
TYPESCRIPT_STRICT_PLAN.md

# Do not commit the report PDF into public assets
/public/PROJECT_REPORT.pdf

# Environment variables (secrets — never commit)
.env*
!.env.example

# SQLite database files (runtime data — never commit)
/db/*.db
/db/*.db-journal
*.sqlite
*.sqlite-journal

# Dev examples / demo folder
/examples/
# Mobile app (Expo)
apps/mobile/.env
apps/mobile/.env.local
apps/mobile/node_modules
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/web-build/
apps/mobile/ios/
apps/mobile/android/
*.tsbuildinfo

# Local browser/dev-tool output
.playwright-mcp/
