generator client {
  provider   = "prisma-client-js"
  engineType = "wasm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum User_Role {
  CUSTOMER
  ADMIN
}

enum Order_Status {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum Payment_Status {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum Payment_Method {
  SSLCOMMERZ
  BKASH
  NAGAD
  COD
  BANK_TRANSFER
}

enum Service_Status {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Booking_Status {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Review_Status {
  PENDING
  APPROVED
  REJECTED
}

enum Newsletter_Status {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

enum Contact_Status {
  NEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TaxType {
  PERCENTAGE
  FLAT
}

enum Shipping_Status {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

// ==================== MODELS ====================

model User {
  id        String     @id @default(uuid()) @db.VarChar(36)
  name      String     @db.VarChar(100)
  nameBn    String?    @db.VarChar(100) @map("name_bn")
  email     String     @unique @db.VarChar(255)
  phone     String     @unique @db.VarChar(20)
  password  String     @db.VarChar(255)
  role      User_Role  @default(CUSTOMER)
  avatar    String?    @db.VarChar(500)
  isActive  Boolean    @default(true) @map("is_active")
  isDeleted Boolean    @default(false) @map("is_deleted")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  addresses       UserAddress[]
  orders          Order[]
  reviews         Review[]
  wishlistItems   Wishlist[]
  quoteRequests    QuoteRequest[]
  serviceBookings ServiceBooking[]
  cartItems       CartItem[]
  contacts        Contact[]
  newsletters     Newsletter[]
  orderHistories  OrderHistory[]
  couponUsages    CouponUsage[]
  returnRequests  ReturnRequest[]
  notifications   Notification[]
  questions       ProductQuestion[]

  @@map("users")
}

model UserAddress {
  id          String   @id @default(cuid())
  userId      String   @db.VarChar(36) @map("user_id")
  label       String?  @db.VarChar(50)
  fullName    String   @db.VarChar(100) @map("full_name")
  phone       String   @db.VarChar(20)
  address     String   @db.VarChar(500)
  city        String   @db.VarChar(100)
  area        String?  @db.VarChar(100)
  postalCode  String?  @db.VarChar(20) @map("postal_code")
  isDefault   Boolean  @default(false) @map("is_default")
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@index([userId])
  @@map("user_addresses")
}

model Brand {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(100)
  nameBn    String?  @db.VarChar(100) @map("name_bn")
  slug      String   @unique @db.VarChar(120)
  logo      String?  @db.VarChar(500)
  country   String?  @db.VarChar(100)
  website   String?  @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("brands")
}

model ProductCategory {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(100)
  nameBn    String   @db.VarChar(100) @map("name_bn")
  slug      String   @unique @db.VarChar(120)
  icon      String?  @db.VarChar(100)
  image     String?  @db.VarChar(500)
  parentId  String?  @db.VarChar(36) @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products  Product[]
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryHierarchy")

  @@map("product_categories")
}

model Product {
  id          String           @id @default(uuid()) @db.VarChar(36)
  name        String           @db.VarChar(200)
  nameBn      String?          @db.VarChar(200) @map("name_bn")
  slug        String           @unique @db.VarChar(220)
  description String           @db.Text
  shortDesc   String?          @db.VarChar(500) @map("short_desc")
  sku         String?          @unique @db.VarChar(50)
  price       Decimal          @db.Decimal(10, 2)
  salePrice   Decimal?         @db.Decimal(10, 2) @map("sale_price")
  costPrice   Decimal?         @db.Decimal(10, 2) @map("cost_price")
  stock       Int              @default(0)
  minStock    Int              @default(5) @map("min_stock")
  images      String[]         @db.VarChar(500)
  specs       Json?
  isFeatured  Boolean          @default(false) @map("is_featured")
  hasVariant  Boolean          @default(false) @map("has_variant")
  isActive    Boolean          @default(true) @map("is_active")
  isDeleted   Boolean          @default(false) @map("is_deleted")
  brandId     String           @db.VarChar(36) @map("brand_id")
  categoryId  String           @db.VarChar(36) @map("category_id")
  tags        String[]         @db.VarChar(100)
  rating      Decimal          @default(0) @db.Decimal(2, 1)
  reviewCount Int              @default(0) @map("review_count")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  brand     Brand            @relation(fields: [brandId], references: [id])
  category  ProductCategory  @relation(fields: [categoryId], references: [id])
  variants  ProductVariant[]
  reviews   Review[]
  wishlistItems Wishlist[]
  cartItems CartItem[]
  orderItems OrderItem[]
  flashSaleId String?           @db.VarChar(36) @map("flash_sale_id")
  flashSale   FlashSale?        @relation(fields: [flashSaleId], references: [id])
  taxId       String?           @db.VarChar(36) @map("tax_id")
  tax         Tax?              @relation(fields: [taxId], references: [id])
  questions   ProductQuestion[]

  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String   @db.VarChar(36) @map("product_id")
  name       String   @db.VarChar(200)
  sku        String   @unique @db.VarChar(50)
  price      Decimal  @db.Decimal(10, 2)
  salePrice  Decimal? @db.Decimal(10, 2) @map("sale_price")
  stock      Int      @default(0)
  attributes Json
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model CartItem {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36) @map("user_id")
  productId String   @db.VarChar(36) @map("product_id")
  variantId String?  @db.VarChar(36) @map("variant_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36) @map("user_id")
  productId String   @db.VarChar(36) @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}

model Order {
  id              String         @id @default(uuid()) @db.VarChar(36)
  orderNumber     String         @unique @db.VarChar(20) @map("order_number")
  userId          String         @db.VarChar(36) @map("user_id")
  subtotal        Decimal        @db.Decimal(10, 2)
  deliveryCharge  Decimal        @default(0) @db.Decimal(10, 2) @map("delivery_charge")
  discount        Decimal        @default(0) @db.Decimal(10, 2)
  total           Decimal        @db.Decimal(10, 2)
  status          Order_Status   @default(PENDING)
  paymentStatus   Payment_Status @default(PENDING) @map("payment_status")
  paymentMethod   Payment_Method @map("payment_method")
  couponId        String?        @db.VarChar(36) @map("coupon_id")
  addressId       String         @db.VarChar(36) @map("address_id")
  notes           String?        @db.VarChar(500)
  deliveredAt     DateTime?      @map("delivered_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id])
  address  UserAddress @relation(fields: [addressId], references: [id])
  items    OrderItem[]
  payments Payment[]
  histories OrderHistory[]
  couponUsages CouponUsage[]
  coupon   Coupon?     @relation(fields: [couponId], references: [id])
  shipment Shipment?
  returnRequests ReturnRequest[]

  @@index([addressId])
  @@map("orders")
}

model OrderHistory {
  id        String       @id @default(cuid())
  orderId   String       @db.VarChar(36) @map("order_id")
  userId    String       @db.VarChar(36) @map("user_id")
  status    Order_Status
  note      String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@map("order_histories")
}

model ReturnRequest {
  id           String   @id @default(cuid())
  orderId      String   @db.VarChar(36) @map("order_id")
  userId       String   @db.VarChar(36) @map("user_id")
  reason       String   @db.Text
  status       String   @default("PENDING") @db.VarChar(20) // PENDING, APPROVED, REJECTED, COMPLETED
  refundAmount Decimal? @db.Decimal(10, 2) @map("refund_amount")
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("return_requests")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @db.VarChar(36) @map("user_id")
  title     String   @db.VarChar(200)
  message   String   @db.Text
  type      String   @default("INFO") @db.VarChar(30) // RETURN, ORDER, INFO, etc.
  isRead    Boolean  @default(false) @map("is_read")
  relatedId String?  @db.VarChar(36) @map("related_id") // e.g. return request id
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Payment {
  id               String         @id @default(cuid())
  orderId          String?        @db.VarChar(36) @map("order_id")
  serviceBookingId String?        @db.VarChar(36) @map("service_booking_id")
  amount           Decimal        @db.Decimal(10, 2)
  method           Payment_Method
  status           Payment_Status @default(PENDING)
  transactionId    String?        @unique @db.VarChar(200) @map("transaction_id")
  paymentData      Json?          @map("payment_data")
  paidAt           DateTime?      @map("paid_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  order          Order?          @relation(fields: [orderId], references: [id])
  serviceBooking ServiceBooking? @relation(fields: [serviceBookingId], references: [id])

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model OrderItem {
  id           String   @id @default(uuid()) @db.VarChar(36)
  orderId      String   @db.VarChar(36) @map("order_id")
  productId    String   @db.VarChar(36) @map("product_id")
  variantId    String?  @db.VarChar(36) @map("variant_id")
  productName  String   @db.VarChar(200) @map("product_name")
  productImage String?  @db.VarChar(500) @map("product_image")
  variantName  String?  @db.VarChar(200) @map("variant_name")
  price        Decimal  @db.Decimal(10, 2)
  quantity     Int
  total        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Shipment {
  id                String          @id @default(cuid())
  orderId           String          @unique @db.VarChar(36) @map("order_id")
  trackingNumber    String?         @unique @db.VarChar(100) @map("tracking_number")
  carrier           String?         @db.VarChar(50)
  status            Shipping_Status @default(PENDING)
  estimatedDelivery DateTime?       @map("estimated_delivery")
  shippedAt         DateTime?       @map("shipped_at")
  deliveredAt       DateTime?       @map("delivered_at")
  notes             String?         @db.Text
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  histories ShipmentHistory[]

  @@index([status])
  @@index([trackingNumber])
  @@map("shipments")
}

model ShipmentHistory {
  id         String          @id @default(cuid())
  shipmentId String          @db.VarChar(36) @map("shipment_id")
  status     Shipping_Status
  note       String?         @db.Text
  location   String?         @db.VarChar(200)
  createdAt  DateTime        @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_histories")
}

model Coupon {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        String    @unique @db.VarChar(20)
  name        String    @db.VarChar(100)
  nameBn      String?   @db.VarChar(100) @map("name_bn")
  description String?   @db.VarChar(500)
  type        String    @db.VarChar(20) // PERCENTAGE, FIXED
  value       Decimal   @db.Decimal(10, 2)
  minOrder    Decimal?  @db.Decimal(10, 2) @map("min_order")
  maxDiscount Decimal?  @db.Decimal(10, 2) @map("max_discount")
  usageLimit  Int?      @map("usage_limit")
  usedCount   Int       @default(0) @map("used_count")
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  orders Order[]
  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String   @db.VarChar(36) @map("coupon_id")
  userId    String   @db.VarChar(36) @map("user_id")
  orderId   String?  @db.VarChar(36) @map("order_id")
  createdAt DateTime @default(now()) @map("created_at")

  coupon Coupon  @relation(fields: [couponId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  order  Order?  @relation(fields: [orderId], references: [id])

  @@unique([couponId, userId])
  @@index([userId])
  @@map("coupon_usages")
}

model ServiceCategory {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(100)
  nameBn    String   @db.VarChar(100) @map("name_bn")
  slug      String   @unique @db.VarChar(120)
  icon      String?  @db.VarChar(100)
  image     String?  @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services Service[]

  @@map("service_categories")
}

model Service {
  id          String           @id @default(uuid()) @db.VarChar(36)
  name        String           @db.VarChar(200)
  nameBn      String?          @db.VarChar(200) @map("name_bn")
  slug        String           @unique @db.VarChar(220)
  description String           @db.Text
  shortDesc   String?          @db.VarChar(500) @map("short_desc")
  basePrice   Decimal          @db.Decimal(10, 2) @map("base_price")
  priceUnit   String           @db.VarChar(20) @map("price_unit") // per_call, per_day, per_hour, fixed
  images      String[]         @db.VarChar(500)
  features    Json?
  isFeatured  Boolean          @default(false) @map("is_featured")
  isActive    Boolean          @default(true) @map("is_active")
  isDeleted   Boolean          @default(false) @map("is_deleted")
  categoryId  String           @db.VarChar(36) @map("category_id")
  rating      Decimal          @default(0) @db.Decimal(2, 1)
  reviewCount Int              @default(0) @map("review_count")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  category ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings ServiceBooking[]

  @@map("services")
}

model ServiceBooking {
  id             String         @id @default(uuid()) @db.VarChar(36)
  userId         String         @db.VarChar(36) @map("user_id")
  serviceId      String         @db.VarChar(36) @map("service_id")
  bookingDate    DateTime       @map("booking_date")
  bookingTime    String         @db.VarChar(10) @map("booking_time")
  status         Booking_Status @default(PENDING)
  notes          String?        @db.VarChar(500)
  address        String         @db.VarChar(500)
  phone          String         @db.VarChar(20)
  totalCost      Decimal        @db.Decimal(10, 2) @map("total_cost")
  paymentStatus  Payment_Status @default(PENDING) @map("payment_status")
  paymentMethod  Payment_Method? @map("payment_method")
  isDeleted      Boolean         @default(false) @map("is_deleted")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])
  payments Payment[]

  @@map("service_bookings")
}

model Review {
  id        String        @id @default(uuid()) @db.VarChar(36)
  userId    String        @db.VarChar(36) @map("user_id")
  productId String?       @db.VarChar(36) @map("product_id")
  rating    Int
  title     String        @db.VarChar(200)
  comment   String        @db.VarChar(1000)
  status    Review_Status @default(PENDING)
  isDeleted Boolean       @default(false) @map("is_deleted")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@map("reviews")
}

model BlogPost {
  id         String   @id @default(uuid()) @db.VarChar(36)
  title      String   @db.VarChar(200)
  titleBn    String?  @db.VarChar(200) @map("title_bn")
  slug       String   @unique @db.VarChar(220)
  content    String   @db.Text
  excerpt    String?  @db.VarChar(500)
  coverImage String?  @db.VarChar(500) @map("cover_image")
  author     String?  @db.VarChar(100)
  tags       String[] @db.VarChar(100)
  isPublished Boolean  @default(false) @map("is_published")
  isDeleted  Boolean  @default(false) @map("is_deleted")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model QuoteRequest {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String?  @db.VarChar(36) @map("user_id")
  name        String   @db.VarChar(100)
  phone       String   @db.VarChar(20)
  email       String?  @db.VarChar(255)
  serviceType String   @db.VarChar(100) @map("service_type")
  description String   @db.VarChar(1000)
  address     String?  @db.VarChar(500)
  budget      String?  @db.VarChar(100)
  status      String   @default("PENDING") @db.VarChar(20)
  isDeleted   Boolean  @default(false) @map("is_deleted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("quote_requests")
}

model Contact {
  id        String         @id @default(uuid()) @db.VarChar(36)
  userId    String?        @db.VarChar(36) @map("user_id")
  name      String         @db.VarChar(100)
  email     String         @db.VarChar(255)
  phone     String?        @db.VarChar(20)
  subject   String         @db.VarChar(200)
  message   String         @db.VarChar(2000)
  status    Contact_Status @default(NEW)
  isDeleted Boolean        @default(false) @map("is_deleted")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("contacts")
}

model Newsletter {
  id        String            @id @default(uuid()) @db.VarChar(36)
  userId    String?           @db.VarChar(36) @map("user_id")
  email     String            @unique @db.VarChar(255)
  status    Newsletter_Status @default(ACTIVE)
  isDeleted Boolean           @default(false) @map("is_deleted")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("newsletters")
}

model Project {
  id          String   @id @default(uuid()) @db.VarChar(36)
  title       String   @db.VarChar(200)
  titleBn     String?  @db.VarChar(200) @map("title_bn")
  slug        String   @unique @db.VarChar(220)
  description String   @db.Text
  coverImage  String?  @db.VarChar(500) @map("cover_image")
  images      String[] @db.VarChar(500)
  client      String?  @db.VarChar(100)
  location    String?  @db.VarChar(100)
  status      String   @default("COMPLETED") @db.VarChar(20)
  isDeleted   Boolean  @default(false) @map("is_deleted")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model FlashSale {
  id          String    @id @default(uuid()) @db.VarChar(36)
  title       String    @db.VarChar(200)
  description String?   @db.Text
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  discount    Decimal   @db.Decimal(5, 2)
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("flash_sales")
}

model Tax {
  id        String   @id @default(uuid()) @db.VarChar(36)
  name      String   @db.VarChar(100)
  rate      Decimal  @db.Decimal(5, 2)
  type      TaxType  @default(PERCENTAGE)
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("taxes")
}

model ProductQuestion {
  id         String    @id @default(uuid()) @db.VarChar(36)
  productId  String    @db.VarChar(36) @map("product_id")
  userId     String    @db.VarChar(36) @map("user_id")
  question   String    @db.VarChar(500)
  answer     String?   @db.VarChar(1000)
  answeredAt DateTime? @map("answered_at")
  isDeleted  Boolean   @default(false) @map("is_deleted")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@map("product_questions")
}
